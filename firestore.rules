rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Chỉ cho phép đọc điểm số công khai
    match /scores/{score} {
      allow read: if true;
      // Chỉ cho phép user đã đăng nhập được ghi điểm
      allow create: if request.auth != null; 
    }
    // User documents có thể đọc được khi đã đăng nhập để tìm bạn bè
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }
    match /friend_chats/{chatId}/messages/{messageId} {
      allow read, create: if request.auth != null &&
        (chatId.matches('(^' + request.auth.uid + '_.*$)|(^.*_' + request.auth.uid + '$)'));
      allow update, delete: if false;
    }
  }
}